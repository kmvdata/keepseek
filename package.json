{
  "name": "keepseek",
  "displayName": "KeepSeek",
  "description": "AI-powered coding agent for VS Code",
  "version": "0.0.2",
  "publisher": "keepseek",
  "icon": "resources/keepseek.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/keepseek/keepseek"
  },
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onWebviewPanel:keepseek.chatView",
    "onWebviewPanel:keepseek.chatSecondaryView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "keepseek",
          "title": "KeepSeek",
          "icon": "resources/keepseek.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "keepseek-secondary",
          "title": "KeepSeek",
          "icon": "resources/keepseek.svg"
        }
      ]
    },
    "views": {
      "keepseek": [
        {
          "type": "keepseek.chatView",
          "id": "keepseek.chatView",
          "name": "KeepSeek"
        }
      ],
      "keepseek-secondary": [
        {
          "type": "keepseek.chatSecondaryView",
          "id": "keepseek.chatSecondaryView",
          "name": "KeepSeek"
        }
      ]
    },
    "commands": [
      {
        "command": "keepseek.openChat",
        "title": "KeepSeek: Open Agent Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "keepseek.addCurrentFileToContext",
        "title": "KeepSeek: Add Current File to Context",
        "icon": "$(add)"
      },
      {
        "command": "keepseek.pickWorkspaceFilesToContext",
        "title": "KeepSeek: Pick Workspace Files...",
        "icon": "$(folder-opened)"
      },
      {
        "command": "keepseek.pickExternalFilesToContext",
        "title": "KeepSeek: Add External Files to Context...",
        "icon": "$(link-external)"
      },
      {
        "command": "keepseek.addSelectionToContext",
        "title": "KeepSeek: Add Selection to Chat",
        "icon": "$(whole-word)"
      },
      {
        "command": "keepseek.addExplorerFileToContext",
        "title": "KeepSeek: Add Explorer File to Chat",
        "icon": "$(file-add)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "keepseek.addExplorerFileToContext",
          "when": "explorerViewletFocus && !explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "keepseek.addSelectionToContext",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "keepseek.addCurrentFileToContext",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "keepseek.pickWorkspaceFilesToContext",
          "when": "view == keepseek.chatView",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "keepseek.addSelectionToContext",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorHasSelection && editorTextFocus"
      },
      {
        "command": "keepseek.addExplorerFileToContext",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "explorerViewletFocus && !explorerResourceIsFolder"
      }
    ],
    "configuration": {
      "title": "KeepSeek",
      "properties": {
        "keepseek.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authentication"
        },
        "keepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "Base URL for the API endpoint"
        },
        "keepseek.models": {
          "type": "array",
          "default": [
            {
              "id": "deepseek-v4-flash",
              "label": "DeepSeek-V4-Flash",
              "provider": "deepseek"
            },
            {
              "id": "deepseek-v4-pro",
              "label": "DeepSeek-V4-Pro",
              "provider": "deepseek"
            }
          ],
          "description": "Available AI models"
        },
        "keepseek.thinkingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable thinking mode for the agent"
        },
        "keepseek.reasoningEffort": {
          "type": "string",
          "enum": [
            "high",
            "max"
          ],
          "default": "high",
          "description": "Reasoning effort level"
        },
        "keepseek.maxFileBytes": {
          "type": "number",
          "default": 200000,
          "description": "Maximum file size in bytes for reading"
        },
        "keepseek.language": {
          "type": "string",
          "enum": [
            "zh-CN",
            "en"
          ],
          "default": "zh-CN",
          "description": "Language for the KeepSeek UI"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile && npm run lint"
  },
  "devDependencies": {
    "@types/vscode": "^1.106.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "openai": "^4.0.0"
  }
}
