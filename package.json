{
  "name": "keepseek",
  "displayName": "KeepSeek",
  "description": "AI-powered coding agent for VS Code",
  "version": "0.1.5",
  "publisher": "keepseek",
  "author": "kmvdata",
  "license": "MIT",
  "icon": "resources/keepseek.png",
  "homepage": "https://github.com/kmvdata/keepseek#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kmvdata/keepseek.git"
  },
  "bugs": {
    "url": "https://github.com/kmvdata/keepseek/issues"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Chat",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "deepseek",
    "agent",
    "coding",
    "ai"
  ],
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#1C1C1C",
    "theme": "dark"
  },
  "activationEvents": [
    "onView:keepseek.chat",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "keepseek.focus",
        "title": "KeepSeek: Focus on KeepSeek View"
      },
      {
        "command": "keepseek.newChat",
        "title": "KeepSeek: New Chat"
      },
      {
        "command": "keepseek.toggleMode",
        "title": "KeepSeek: Toggle Mode"
      },
      {
        "command": "keepseek.clearHistory",
        "title": "KeepSeek: Clear All History"
      },
      {
        "command": "keepseek.selectRange",
        "title": "KeepSeek: Select Range to Ask"
      },
      {
        "command": "keepseek.openChat",
        "title": "KeepSeek: Open Chat"
      },
      {
        "command": "keepseek.addCurrentFileToContext",
        "title": "KeepSeek: Add Current File to Context"
      },
      {
        "command": "keepseek.pickWorkspaceFilesToContext",
        "title": "KeepSeek: Add Workspace Files to Context"
      },
      {
        "command": "keepseek.pickExternalFilesToContext",
        "title": "KeepSeek: Add External Files to Context"
      },
      {
        "command": "keepseek.addSelectionToContext",
        "title": "KeepSeek: Add Selection to Chat"
      },
      {
        "command": "keepseek.addTerminalSelectionToContext",
        "title": "KeepSeek: Add Terminal Selection to Chat"
      },
      {
        "command": "keepseek.addDebugConsoleSelectionToContext",
        "title": "KeepSeek: Add Debug Console Selection to Chat"
      },
      {
        "command": "keepseek.addExplorerFileToContext",
        "title": "KeepSeek: Add File to Chat"
      },
      {
        "command": "keepseek.addExplorerDirectoryToContext",
        "title": "KeepSeek: Add Folder to Chat"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "keepseek.addSelectionToContext",
          "when": "editorHasSelection",
          "group": "keepseek@1"
        }
      ],
      "explorer/context": [
        {
          "command": "keepseek.addExplorerFileToContext",
          "when": "!explorerResourceIsFolder",
          "group": "keepseek@1"
        },
        {
          "command": "keepseek.addExplorerDirectoryToContext",
          "when": "explorerResourceIsFolder",
          "group": "keepseek@2"
        }
      ],
      "terminal/context": [
        {
          "command": "keepseek.addTerminalSelectionToContext",
          "when": "terminalTextSelectedInFocused",
          "group": "keepseek@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "keepseek-sidebar",
          "title": "KeepSeek",
          "icon": "resources/keepseek.svg"
        }
      ]
    },
    "views": {
      "keepseek-sidebar": [
        {
          "type": "webview",
          "id": "keepseek.chat",
          "name": "Chat",
          "icon": "resources/keepseek.svg"
        }
      ]
    },
    "keybindings": [
      {
        "command": "keepseek.focus",
        "key": "alt+k",
        "mac": "alt+k"
      },
      {
        "command": "keepseek.newChat",
        "key": "alt+shift+k",
        "mac": "alt+shift+k"
      },
      {
        "command": "keepseek.selectRange",
        "key": "alt+l",
        "mac": "alt+l"
      }
    ],
    "configuration": {
      "title": "KeepSeek",
      "properties": {
        "keepseek.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your DeepSeek API key. If set, this takes precedence over the `DEEPSEEK_API_KEY` environment variable.\n\nIf both are empty, KeepSeek will prompt you to enter the key on first use."
        },
        "keepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "scope": "application",
          "markdownDescription": "Base URL for the DeepSeek V4 API. Defaults to `https://api.deepseek.com`."
        },
        "keepseek.systemPrompt": {
          "type": "string",
          "default": "",
          "markdownDescription": "Custom system prompt to prepend to all conversations."
        },
        "keepseek.useGit": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable Git integration for context-aware suggestions."
        },
        "keepseek.useActiveEditor": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Include active editor content as context automatically."
        },
        "keepseek.maxHistoryMessages": {
          "type": "number",
          "default": 80,
          "markdownDescription": "Maximum number of chat history messages to retain per session."
        },
        "keepseek.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh-CN",
            "zh-TW",
            "ja",
            "ko"
          ],
          "markdownDescription": "Language preference. `auto` follows VS Code display language."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "build:prod": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "lint": "eslint src/ test/",
    "test": "node out-test/test/runTests.js",
    "package": "npx @vscode/vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.98.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.24.0",
    "neostandard": "^0.12.1",
    "typescript": "^5.8.3"
  }
}
