{
  "name": "keepseek",
  "displayName": "KeepSeek",
  "description": "AI-powered coding agent for VS Code",
  "version": "0.0.9",
  "publisher": "keepseek",
  "icon": "resources/keepseek.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/keepseek/keepseek"
  },
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onView:keepseek.chatView",
    "onCommand:keepseek.openChat",
    "onCommand:keepseek.addCurrentFileToContext",
    "onCommand:keepseek.pickWorkspaceFilesToContext",
    "onCommand:keepseek.pickExternalFilesToContext",
    "onCommand:keepseek.addSelectionToContext",
    "onCommand:keepseek.addExplorerFileToContext",
    "onCommand:keepseek.addExplorerDirectoryToContext",
    "onCommand:keepseek.addTerminalSelectionToContext",
    "onCommand:keepseek.addDebugConsoleSelectionToContext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "keepseek",
          "title": "KeepSeek",
          "icon": "resources/keepseek.svg"
        }
      ]
    },
    "views": {
      "keepseek": [
        {
          "type": "webview",
          "id": "keepseek.chatView",
          "name": "KeepSeek",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "keepseek.openChat",
        "title": "KeepSeek: Open Agent Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "keepseek.addCurrentFileToContext",
        "title": "KeepSeek: Add Current File to Context",
        "icon": "$(add)"
      },
      {
        "command": "keepseek.pickWorkspaceFilesToContext",
        "title": "KeepSeek: Pick Workspace Files...",
        "icon": "$(folder-opened)"
      },
      {
        "command": "keepseek.pickExternalFilesToContext",
        "title": "KeepSeek: Add External Files to Context...",
        "icon": "$(link-external)"
      },
      {
        "command": "keepseek.addSelectionToContext",
        "title": "KeepSeek: 添加到上下文",
        "icon": "$(whole-word)"
      },
      {
        "command": "keepseek.addTerminalSelectionToContext",
        "title": "KeepSeek: 添加到上下文",
        "icon": "$(terminal)"
      },
      {
        "command": "keepseek.addDebugConsoleSelectionToContext",
        "title": "KeepSeek: 添加到上下文",
        "icon": "$(debug-console)"
      },
      {
        "command": "keepseek.addExplorerFileToContext",
        "title": "KeepSeek: Add Explorer File to Chat",
        "icon": "$(file-add)"
      },
      {
        "command": "keepseek.addExplorerDirectoryToContext",
        "title": "KeepSeek: Add Explorer Folder to Chat",
        "icon": "$(folder-opened)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "keepseek.addExplorerFileToContext",
          "when": "!explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "keepseek.addExplorerDirectoryToContext",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "keepseek.addSelectionToContext",
          "when": "editorHasSelection && !inDebugRepl",
          "group": "navigation"
        },
        {
          "command": "keepseek.addDebugConsoleSelectionToContext",
          "when": "inDebugRepl",
          "group": "navigation"
        }
      ],
      "terminal/context": [
        {
          "command": "keepseek.addTerminalSelectionToContext",
          "when": "terminalTextSelected",
          "group": "3_edit"
        }
      ],
      "editor/title": [
        {
          "command": "keepseek.addCurrentFileToContext",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "keepseek.pickWorkspaceFilesToContext",
          "when": "view == keepseek.chatView",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "keepseek.addSelectionToContext",
        "key": "ctrl+shift+l",
        "mac": "cmd+l",
        "when": "editorHasSelection && editorTextFocus && !inDebugRepl"
      },
      {
        "command": "keepseek.addExplorerFileToContext",
        "key": "ctrl+shift+l",
        "mac": "cmd+l",
        "when": "explorerViewletFocus && !explorerResourceIsFolder"
      },
      {
        "command": "keepseek.addExplorerDirectoryToContext",
        "key": "ctrl+shift+l",
        "mac": "cmd+l",
        "when": "explorerViewletFocus && explorerResourceIsFolder"
      },
      {
        "command": "keepseek.addTerminalSelectionToContext",
        "key": "ctrl+shift+l",
        "mac": "cmd+l",
        "when": "terminalFocus && terminalTextSelectedInFocused"
      },
      {
        "command": "keepseek.addDebugConsoleSelectionToContext",
        "key": "ctrl+shift+l",
        "mac": "cmd+l",
        "when": "inDebugRepl"
      }
    ],
    "configuration": {
      "title": "KeepSeek",
      "properties": {
        "keepseek.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authentication"
        },
        "keepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "Base URL for the API endpoint"
        },
        "keepseek.models": {
          "type": "array",
          "default": [
            {
              "id": "deepseek-v4-flash",
              "label": "DeepSeek-V4-Flash",
              "provider": "deepseek"
            },
            {
              "id": "deepseek-v4-pro",
              "label": "DeepSeek-V4-Pro",
              "provider": "deepseek"
            }
          ],
          "description": "Available AI models"
        },
        "keepseek.selectedModelId": {
          "type": "string",
          "default": "",
          "description": "Persisted ID of the currently selected AI model. When empty or unavailable, KeepSeek uses the first configured model."
        },
        "keepseek.thinkingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable thinking mode for the agent"
        },
        "keepseek.reasoningEffort": {
          "type": "string",
          "enum": [
            "high",
            "max"
          ],
          "default": "high",
          "description": "Reasoning effort level"
        },
        "keepseek.maxFileBytes": {
          "type": "number",
          "default": 200000,
          "description": "Maximum file size in bytes for reading"
        },
        "keepseek.maxTokens": {
          "type": "number",
          "default": 64000,
          "minimum": 0,
          "maximum": 384000,
          "description": "Maximum generated tokens per request. Set 0 to omit max_tokens and use the provider default."
        },
        "keepseek.maxToolIterations": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "maximum": 64,
          "description": "Maximum agent tool-use rounds before the agent must answer without more tools. Set 0 to disable tool use."
        },
        "keepseek.maxToolCalls": {
          "type": "number",
          "default": 24,
          "minimum": 0,
          "maximum": 256,
          "description": "Maximum total tool calls in one agent run. Set 0 to disable this separate tool-call cap."
        },
        "keepseek.maxRunMs": {
          "type": "number",
          "default": 600000,
          "minimum": 0,
          "maximum": 3600000,
          "description": "Maximum total run time in milliseconds for one agent run. Set 0 to disable the total run-time cap."
        },
        "keepseek.toolResultTokenBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1000000,
          "description": "Maximum estimated tokens reserved for tool results in one agent run. Set 0 to automatically derive the budget from the selected model context window."
        },
        "keepseek.maxWorkspaceToolFiles": {
          "type": "number",
          "default": 2000,
          "description": "Maximum number of workspace files returned to the agent by the read-only file listing tool"
        },
        "keepseek.contextWindowTokens": {
          "type": "number",
          "default": 1000000,
          "description": "Estimated context window size in tokens for the context usage indicator"
        },
        "keepseek.streamIdleTimeoutMs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 3600000,
          "description": "Maximum time in milliseconds to wait for streaming data before stopping a DeepSeek request. This resets whenever streaming data is received and does not limit total run duration. Set 0 to disable the idle timeout."
        },
        "keepseek.historyRetentionDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 365,
          "description": "Number of days to retain non-favorited historical sessions based on their last update time."
        },
        "keepseek.language": {
          "type": "string",
          "enum": [
            "zh-CN",
            "en"
          ],
          "default": "zh-CN",
          "description": "Language for the KeepSeek UI"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "pretest": "npm run compile && npm run lint"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.106.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^7.18.0"
  },
  "dependencies": {
    "openai": "^4.0.0"
  }
}
