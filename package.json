{
  "name": "keepseek",
  "displayName": "KeepSeek",
  "description": "AI-powered coding agent for VS Code",
  "publisher": "keepseek",
  "version": "0.1.9",
  "license": "MIT",
  "icon": "resources/keepseek.png",
  "homepage": "https://github.com/kmvdata/keepseek#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kmvdata/keepseek.git"
  },
  "bugs": {
    "url": "https://github.com/kmvdata/keepseek/issues"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "deepseek",
    "coding agent",
    "chat"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "keepseek.focus",
        "title": "Open KeepSeek"
      },
      {
        "command": "keepseek.addSelectionToContext",
        "title": "KeepSeek: Add Selection to Context"
      },
      {
        "command": "keepseek.addExplorerFileToContext",
        "title": "KeepSeek: Add File to Context"
      },
      {
        "command": "keepseek.addExplorerDirectoryToContext",
        "title": "KeepSeek: Add Explorer Folder to Chat"
      }
    ],
    "configuration": {
      "title": "KeepSeek",
      "properties": {
        "keepseek.apiKey": {
          "type": "string",
          "default": "",
          "description": "DeepSeek API key"
        },
        "keepseek.apiBaseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API base URL"
        },
        "keepseek.model": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "Model name for chat completions"
        },
        "keepseek.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "zh-CN",
            "en-US"
          ],
          "description": "Language for KeepSeek UI and replies"
        },
        "keepseek.maxTokens": {
          "type": "number",
          "default": 8192,
          "minimum": 256,
          "maximum": 65536,
          "description": "Maximum tokens per response"
        },
        "keepseek.maxFileBytes": {
          "type": "number",
          "default": 65536,
          "minimum": 1024,
          "maximum": 524288,
          "description": "Maximum file size in bytes for context files"
        },
        "keepseek.maxContextFiles": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum number of context files"
        },
        "keepseek.contextCompressionEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable context compression for long conversations"
        },
        "keepseek.contextKeepRecentTurns": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 50,
          "description": "Number of recent user turns to keep in projection"
        },
        "keepseek.contextCompressionTriggerRatio": {
          "type": "number",
          "default": 0.8,
          "minimum": 0.5,
          "maximum": 1.0,
          "description": "Context usage ratio to trigger summary refresh"
        },
        "keepseek.contextSummaryBudgetTokens": {
          "type": "number",
          "default": 512,
          "minimum": 128,
          "maximum": 4096,
          "description": "Token budget for summary generation"
        },
        "keepseek.historyRetentionDays": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 365,
          "description": "Days to keep session history in the picker"
        },
        "keepseek.maxToolIterations": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "maximum": 64,
          "description": "Maximum tool call iterations per run"
        },
        "keepseek.maxToolCalls": {
          "type": "number",
          "default": 24,
          "minimum": 0,
          "maximum": 256,
          "description": "Maximum total tool calls per run"
        },
        "keepseek.maxRunMs": {
          "type": "number",
          "default": 600000,
          "minimum": 0,
          "maximum": 3600000,
          "description": "Maximum run duration in milliseconds"
        },
        "keepseek.toolResultTokenBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1000000,
          "description": "Tool result token budget (0 = auto)"
        },
        "keepseek.thinkingMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable thinking/reasoning mode"
        },
        "keepseek.reasoningEffort": {
          "type": "string",
          "default": "medium",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "description": "Reasoning effort level for thinking mode"
        },
        "keepseek.validation.maxRepairIterations": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "maximum": 10,
          "description": "Maximum repair iterations per validation failure"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "keepseek.addSelectionToContext",
          "group": "KeepSeek@1"
        }
      ],
      "explorer/context": [
        {
          "when": "!explorerResourceIsFolder",
          "command": "keepseek.addExplorerFileToContext",
          "group": "KeepSeek@1"
        },
        {
          "when": "explorerResourceIsFolder",
          "command": "keepseek.addExplorerDirectoryToContext",
          "group": "KeepSeek@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "keepseek.focus",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "build:test": "tsc -p tsconfig.test.json --outDir out-test",
    "test": "node out-test/test/runTests.js",
    "vscode:prepublish": "npm run compile",
    "package": "node scripts/verify-vsix.js",
    "reinstall:vsix": "node scripts/reinstall-vsix.js"
  },
  "dependencies": {
    "ignore": "^5.3.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.98.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/mocha": "^10.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "vsce": "^2.15.0"
  }
}