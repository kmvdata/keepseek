{
  "name": "keepseek",
  "displayName": "KeepSeek",
  "description": "AI-powered coding agent for VS Code",
  "version": "0.1.5",
  "publisher": "keepseek",
  "author": "kmvdata",
  "license": "MIT",
  "icon": "resources/keepseek.png",
  "homepage": "https://github.com/kmvdata/keepseek#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kmvdata/keepseek.git"
  },
  "bugs": {
    "url": "https://github.com/kmvdata/keepseek/issues"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Chat",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "deepseek",
    "agent",
    "coding",
    "ai"
  ],
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#1C1C1C",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out-test/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "keepseek.focus",
        "title": "KeepSeek: Focus on KeepSeek View"
      },
      {
        "command": "keepseek.newChat",
        "title": "KeepSeek: New Chat"
      },
      {
        "command": "keepseek.toggleMode",
        "title": "KeepSeek: Toggle Mode"
      },
      {
        "command": "keepseek.clearHistory",
        "title": "KeepSeek: Clear All History"
      },
      {
        "command": "keepseek.selectRange",
        "title": "KeepSeek: Select Range to Ask"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "keepseek-sidebar",
          "title": "KeepSeek",
          "icon": "resources/keepseek.svg"
        }
      ]
    },
    "views": {
      "keepseek-sidebar": [
        {
          "type": "webview",
          "id": "keepseek.chat",
          "name": "Chat"
        }
      ]
    },
    "keybindings": [
      {
        "command": "keepseek.focus",
        "key": "alt+k",
        "mac": "alt+k"
      },
      {
        "command": "keepseek.newChat",
        "key": "alt+shift+k",
        "mac": "alt+shift+k"
      },
      {
        "command": "keepseek.selectRange",
        "key": "alt+l",
        "mac": "alt+l"
      }
    ],
    "configuration": {
      "title": "KeepSeek",
      "properties": {
        "keepseek.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your DeepSeek API key. If set, this takes precedence over the `DEEPSEEK_API_KEY` environment variable.\n\nIf both are empty, KeepSeek will prompt you to enter the key on first use."
        },
        "keepseek.apiBaseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com/beta",
          "scope": "application",
          "markdownDescription": "Base URL for the DeepSeek API."
        },
        "keepseek.model": {
          "type": "string",
          "default": "deepseek-chat",
          "enum": [
            "deepseek-chat",
            "deepseek-reasoner"
          ],
          "markdownDescription": "DeepSeek model to use (`deepseek-chat` or `deepseek-reasoner`)."
        },
        "keepseek.maxTokens": {
          "type": "integer",
          "default": 8192,
          "minimum": 1024,
          "maximum": 65536,
          "markdownDescription": "Maximum number of tokens to generate per response."
        },
        "keepseek.temperature": {
          "type": "number",
          "default": 0.0,
          "minimum": 0.0,
          "maximum": 2.0,
          "markdownDescription": "Sampling temperature for the model."
        },
        "keepseek.historyRetentionDays": {
          "type": "integer",
          "default": 7,
          "minimum": 1,
          "maximum": 60,
          "markdownDescription": "Number of days of session history to show in the history menu. Sessions older than 60 days are hard-pruned automatically."
        },
        "keepseek.maxTurns": {
          "type": "integer",
          "default": 50,
          "minimum": 5,
          "maximum": 200,
          "markdownDescription": "Maximum number of conversational turns before auto-clearing context."
        },
        "keepseek.locale": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "zh-CN",
            "en-US"
          ],
          "markdownDescription": "Display language (`auto` follows VS Code's UI language)."
        },
        "keepseek.contextCompaction": {
          "type": "object",
          "default": {
            "enabled": true,
            "summaryTriggerRatio": 0.8,
            "recentTurnRetention": 3,
            "summaryBudgetTokens": 2048,
            "toolResultBudgetTokens": 4096,
            "historyProjectionTokens": 2048
          },
          "markdownDescription": "Advanced context compaction settings. Only modify if you understand the trade-offs."
        },
        "keepseek.usagePricing": {
          "type": "object",
          "default": {
            "inputTokenCostPerMillion": 0.27,
            "outputTokenCostPerMillion": 1.10,
            "cacheHitTokenCostPerMillion": 0.07,
            "currency": "USD"
          },
          "markdownDescription": "Per-token pricing for usage cost estimation."
        },
        "keepseek.deepseekBalance": {
          "type": "object",
          "default": {
            "endpoint": "https://api.deepseek.com/user/balance",
            "refreshIntervalMs": 300000
          },
          "markdownDescription": "DeepSeek account balance endpoint and refresh interval."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.test.json",
    "build:prod": "tsc -p tsconfig.test.json",
    "watch": "tsc -watch -p tsconfig.test.json",
    "lint": "eslint src/ test/",
    "test": "node out-test/test/runTests.js",
    "package": "npx @vscode/vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.98.0",
    "@vscode/vsce": "^3.3.0",
    "eslint": "^9.24.0",
    "neostandard": "^0.12.1",
    "typescript": "^5.8.3"
  }
}
