{
  "name": "keepseek",
  "displayName": "KeepSeek",
  "description": "A VS Code agent chat extension for reading project context and safely proposing code edits.",
  "version": "0.0.1",
  "publisher": "keepseek",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:keepseek.chatView",
    "onView:keepseek.chatSecondaryView",
    "onCommand:keepseek.openChat",
    "onCommand:keepseek.addCurrentFileToContext",
    "onCommand:keepseek.pickWorkspaceFilesToContext",
    "onCommand:keepseek.pickExternalFilesToContext",
    "onCommand:keepseek.addSelectionToContext",
    "onCommand:keepseek.addExplorerFileToContext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "keepseek.openChat",
        "title": "KeepSeek: Open Agent Chat"
      },
      {
        "command": "keepseek.addCurrentFileToContext",
        "title": "KeepSeek: Add Current File to Context"
      },
      {
        "command": "keepseek.pickWorkspaceFilesToContext",
        "title": "KeepSeek: Pick Workspace Files for Context"
      },
      {
        "command": "keepseek.pickExternalFilesToContext",
        "title": "KeepSeek: Pick External Files for Context"
      },
      {
        "command": "keepseek.addSelectionToContext",
        "title": "KeepSeek: Add Selection to Context"
      },
      {
        "command": "keepseek.addExplorerFileToContext",
        "title": "KeepSeek: Add File to Context"
      }
    ],
    "configuration": {
      "title": "KeepSeek",
      "properties": {
        "keepseek.models": {
          "type": "array",
          "default": [
            {
              "id": "deepseek-v4-flash",
              "label": "DeepSeek-V4-Flash",
              "provider": "deepseek"
            },
            {
              "id": "deepseek-v4-pro",
              "label": "DeepSeek-V4-Pro",
              "provider": "deepseek"
            }
          ],
          "description": "Models shown in the KeepSeek chat selector. Provider integration is implemented in src/agentRunner.ts."
        },
        "keepseek.apiKey": {
          "type": "string",
          "default": "",
          "scope": "application",
          "description": "DeepSeek 官方 API Key。"
        },
        "keepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "scope": "application",
          "description": "DeepSeek API 端点地址。"
        },
        "keepseek.language": {
          "type": "string",
          "enum": [
            "zh-CN",
            "en"
          ],
          "enumDescriptions": [
            "中文",
            "English"
          ],
          "default": "zh-CN",
          "scope": "application",
          "description": "KeepSeek interface and prompt language."
        },
        "keepseek.thinkingEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "是否启用 DeepSeek thinking 模式。"
        },
        "keepseek.reasoningEffort": {
          "type": "string",
          "enum": [
            "high",
            "max"
          ],
          "default": "high",
          "scope": "application",
          "description": "DeepSeek thinking 模式的推理强度。"
        },
        "keepseek.maxTokens": {
          "type": "number",
          "default": 8192,
          "minimum": 0,
          "maximum": 384000,
          "description": "DeepSeek 单次响应的最大输出 token 数；0 表示不显式传入。"
        },
        "keepseek.maxToolIterations": {
          "type": "number",
          "default": 4,
          "minimum": 0,
          "maximum": 12,
          "description": "Agent 单轮对话最多允许的工具调用迭代次数。"
        },
        "keepseek.requestTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 10000,
          "maximum": 600000,
          "description": "DeepSeek API 请求超时时间，单位毫秒。"
        },
        "keepseek.maxFileBytes": {
          "type": "number",
          "default": 200000,
          "minimum": 1000,
          "description": "Maximum size in bytes for one context file."
        },
        "keepseek.maxContextFiles": {
          "type": "number",
          "default": 32,
          "minimum": 1,
          "description": "Maximum number of files KeepSeek keeps in chat context."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "keepseek",
          "title": "KeepSeek",
          "icon": "resources/keepseek.svg",
          "when": "keepseek.doesNotSupportSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "keepseek-secondary",
          "title": "KeepSeek",
          "icon": "resources/keepseek.svg",
          "when": "!keepseek.doesNotSupportSecondarySidebar"
        }
      ]
    },
    "views": {
      "keepseek": [
        {
          "type": "webview",
          "id": "keepseek.chatView",
          "name": "KeepSeek",
          "when": "keepseek.doesNotSupportSecondarySidebar"
        }
      ],
      "keepseek-secondary": [
        {
          "type": "webview",
          "id": "keepseek.chatSecondaryView",
          "name": "KeepSeek",
          "when": "!keepseek.doesNotSupportSecondarySidebar"
        }
      ]
    },
    "keybindings": [
      {
        "command": "keepseek.addSelectionToContext",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorHasSelection && editorTextFocus"
      },
      {
        "command": "keepseek.addExplorerFileToContext",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "explorerViewletFocus && !explorerResourceIsFolder"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "keepseek.addSelectionToContext",
          "when": "editorHasSelection",
          "group": "keepseek@1"
        }
      ],
      "explorer/context": [
        {
          "command": "keepseek.addExplorerFileToContext",
          "when": "!explorerResourceIsFolder",
          "group": "keepseek@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.18",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.3.2",
    "eslint": "^9.26.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
